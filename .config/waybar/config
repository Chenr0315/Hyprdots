{
  "layer": "top",
  "position": "top",
  "modules-left": [
    "custom/powermenu",
    "hyprland/workspaces",
    "memory",
    "cpu"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "pulseaudio",
    "backlight",
    "network",
    "battery",
    "tray"
  ],
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },
  "backlight": {
    "device": "amd_backlight",
    "on-scroll-up": "light -A 5",
